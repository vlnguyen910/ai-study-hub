// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum userRole {
  USER
  ADMIN
  MODERATOR
}

enum userStatus {
  ACTIVE
  BANNED
  UNVERIFIED
  DELETED
}

enum deviceInfo {
  WEB
  MOBILE
}

model accounts {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  email     String     @unique
  name      String
  password  String
  avatarUrl String
  role      userRole
  status    userStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  //Relationships
  sessions          sessions[]
  documents         documents[] @relation("authorId")
  reviewedDocuments documents[] @relation("reviewedById")
}

model sessions {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  userId       String     @db.ObjectId
  user         accounts   @relation(fields: [userId], references: [id])
  refreshToken String
  deviceInfo   deviceInfo
  isRevoked    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  expiresAt    DateTime

  @@index([userId])
}

model schools {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  code      String   @unique
  createdAt DateTime @default(now())

  //Relationships
  subjects subjects[]
}

model subjects {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  code      String   @unique
  schoolId  String   @db.ObjectId
  createdAt DateTime @default(now())

  //Relationships
  documents documents[]
  school    schools  @relation(fields: [schoolId], references: [id])
}

enum DocumentStatus {
  ACTIVE
  REJECTED
  DELETED
}

model documents {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  description     String?
  fileUrl         String
  publicId        String
  sizeInBytes     Int
  format          String
  resourceType    String
  subjectId       String?         @db.ObjectId
  status          DocumentStatus @default(ACTIVE)
  authorId        String         @db.ObjectId
  isPublic        Boolean        @default(false)
  reviewedById    String?        @db.ObjectId
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  //Relationships
  subject  subjects?  @relation(fields: [subjectId], references: [id])
  author   accounts  @relation("authorId", fields: [authorId], references: [id])
  reviewer accounts? @relation("reviewedById", fields: [reviewedById], references: [id])
}
