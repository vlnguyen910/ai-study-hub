# API runtime
NODE_ENV=development
PORT=8080

# MongoDB connection for Prisma.
# Keep username/password/database aligned with the root .env used by docker-compose.
DATABASE_URL="mongodb://localhost:27011/ai_study_hub?directConnection=true"

# Local seed data
SEED_ACCOUNT_COUNT=20

# JWT for auth flow
JWT_ACCESS_SECRET="replace_with_access_secret"
JWT_REFRESH_SECRET="replace_with_refresh_secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
