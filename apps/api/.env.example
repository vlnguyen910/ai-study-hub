# API runtime
NODE_ENV=development

APP_NAME="AI Study Hub API"
APP_PORT=8080

# MongoDB connection for Prisma.
# Keep username/password/database aligned with the root .env used by docker-compose.
DATABASE_URL="mongodb://localhost:27017/ai-study-hub?directConnection=true"

# Local seed data
SEED_ACCOUNT_COUNT=20
DEFAULT_SCHOOL_CODE="FPTU"

# JWT for auth flow
JWT_SECRET="replace_with_jwt_secret"
JWT_ACCESS_TOKEN_EXPIRES_IN="15m"
JWT_REFRESH_TOKEN_EXPIRES_IN="30d"

# Cookie Configuration (in milliseconds)
COOKIE_ACCESS_TOKEN_MAX_AGE=86400000
COOKIE_REFRESH_TOKEN_MAX_AGE=604800000
COOKIE_HTTP_ONLY=true
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Redis-backed email verification
REDIS_URL="redis://localhost:6379"
REDIS_KEY_PREFIX="ai-study-hub"
EMAIL_VERIFICATION_CODE_LENGTH=6
EMAIL_VERIFICATION_TTL_SECONDS=600
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5

# Resend email delivery
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
RESEND_FROM_NAME=""

FRONTEND_URL="http://localhost:3000"

# Google OAuth
GOOGLE_WEB_CLIENT_ID="PLACE_HOLDER"
GOOGLE_IOS_CLIENT_ID="PLACE_HOLDER"
GOOGLE_ANDROID_CLIENT_ID="PLACE_HOLDER"
GOOGLE_OAUTH_CLIENT_SECRET="PLACE_HOLDER"
GOOGLE_OAUTH_CALLBACK_URL="http://localhost:8080/api/v1/auth/google/callback"
GOOGLE_WEB_SUCCESS_REDIRECT_URL="http://localhost:3000/home"
GOOGLE_WEB_FAILURE_REDIRECT_URL="http://localhost:3000/google/failure"
GOOGLE_OAUTH_STATE_TTL_SECONDS=600
