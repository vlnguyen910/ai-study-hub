# API runtime
NODE_ENV=development
PORT=8080

# MongoDB connection for Prisma.
# Keep username/password/database aligned with the root .env used by docker-compose.
DATABASE_URL="mongodb://localhost:27017/ai-study-hub?directConnection=true"

# Local seed data
SEED_ACCOUNT_COUNT=20

# JWT for auth flow
JWT_SECRET="replace_with_jwt_secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
