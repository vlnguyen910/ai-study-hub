# API runtime
NODE_ENV=development
APP_NAME="AI Study Hub API"
APP_PORT=8080

# CORS configuration
# Development: automatically allows all origins
# Production: requires comma-separated list of allowed origins
# CORS_ORIGINS=https://example.com,https://mobile.example.com

# MongoDB connection for Prisma.
# Keep username/password/database aligned with the root .env used by docker-compose.
DATABASE_URL="mongodb://localhost:27017/ai-study-hub?directConnection=true"

# Local seed data
SEED_ACCOUNT_COUNT=20

# JWT for auth flow
JWT_SECRET="replace_with_jwt_secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"