          "name": "Mobile Signin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const data = body.data || {};",
                  "if (data.accessToken) pm.collectionVariables.set('mobile_access_token', data.accessToken);",
                  "if (data.refreshToken) pm.collectionVariables.set('mobile_refresh_token', data.refreshToken);",
                  "pm.test('mobile signin response is successful', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});"
