    {
      "name": "Auth - Web Cookie Flow",
      "item": [
        {
          "name": "Signup (sets email-verification cookie)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('signup response is successful', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"name\": \"{{name}}\",\n  \"password\": \"{{password}}\",\n  \"avatarUrl\": \"{{avatar_url}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "signup"]
            },
            "description": "Web signup creates an UNVERIFIED account, sends a verification email, and sets an httpOnly accessToken cookie for resend verification."
          },
          "response": []
        },
        {
          "name": "Resend Verification Email (web cookie)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/resend-verification-email",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "resend-verification-email"]
            },
            "description": "Requires the email-verification accessToken cookie from signup. Postman should keep the cookie automatically."
          },
          "response": []
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{verification_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/verify-email",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "verify-email"]
            },
            "description": "Paste the token from the verification email. The API clears the signup accessToken cookie after verification."
          },
          "response": []
        },
        {
          "name": "Signin Web (sets accessToken cookie)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const data = body.data || {};",
                  "if (data.refreshToken) pm.collectionVariables.set('web_refresh_token', data.refreshToken);",
                  "pm.test('web signin response is successful', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"deviceId\": \"{{web_device_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signin",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "signin"]
            },
            "description": "Web login sets httpOnly accessToken cookie and returns refreshToken in the response body."
          },
          "response": []
        },
        {
          "name": "Refresh Web Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const data = body.data || {};",
                  "if (data.accessToken) pm.collectionVariables.set('web_access_token', data.accessToken);",
                  "pm.test('refresh response is successful', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{web_refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Refresh requires refreshToken in the body. The returned accessToken can be copied into bearer requests if needed."
          },
          "response": []
        },
        {
          "name": "Change Password (web cookie)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"{{password}}\",\n  \"newPassword\": \"{{new_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/change-password",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "change-password"]
            },
            "description": "Requires a valid accessToken cookie from web signin."
          },
          "response": []
        },
        {
          "name": "Logout (web cookie)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Requires a valid accessToken cookie from web signin and revokes the current device session."
          },
          "response": []
        }
      ]
