{
  "name": "ai-study-hub",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "db:generate": "pnpm --filter api db:generate",
    "db:sync": "pnpm --filter api db:sync",
    "db:seed": "pnpm --filter api db:seed",
    "db:clean": "pnpm --filter api db:clean",
    "db:reseed": "pnpm --filter api db:reseed",
    "db:studio": "pnpm --filter api db:studio",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/web/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter web exec eslint --fix",
      "prettier --write"
    ],
    "apps/mobile/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter mobile exec eslint --fix",
      "prettier --write"
    ],
    "apps/api/**/*.{js,ts}": [
      "pnpm --filter api exec eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,css,scss,yml,yaml,mjs,cjs}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
